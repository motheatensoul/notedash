{
  "name": "@notedash/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean:cache": "bun --bun -e \"import { rmSync } from 'node:fs'; for (const path of ['node_modules/.vite', '.svelte-kit']) rmSync(path, { recursive: true, force: true });\"",
    "dev": "bun run clean:cache && vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "@lucide/svelte": "^0.561.0",
    "@notedash/types": "workspace:*",
    "@sveltejs/kit": "^2.27.0",
    "@tauri-apps/api": "^2.8.0",
    "svelte": "^5.30.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/types": "^8.40.0",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "csstype": "^3.2.3",
    "svelte-check": "^4.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
